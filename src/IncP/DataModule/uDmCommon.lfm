    SQL.Strings = (
      'SELECT'
      '  RDB$RELATION_NAME AS TABLE_NAME'
      'FROM'
      '  RDB$RELATIONS'
      'WHERE'
      '  (RDB$SYSTEM_FLAG = 0)'
      '  AND (RDB$RELATION_NAME LIKE ''FJ%_MAIN%'')'
      'ORDER BY'
      '  TABLE_NAME'
      ''
    )
