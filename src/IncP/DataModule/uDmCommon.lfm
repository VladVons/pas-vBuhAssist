  object SQLQueryTablesMain: TSQLQuery
    FieldDefs = <>
    Database = IBConnection
    Transaction = SQLTransaction
    SQL.Strings = (
      'SELECT'
      '  RDB$RELATION_NAME AS TABLE_NAME'
      'FROM'
      '  RDB$RELATIONS'
      'WHERE'
      '  (RDB$SYSTEM_FLAG = 0)'
      '  AND (RDB$RELATION_NAME LIKE ''FJ%_MAIN%'')'
      'ORDER BY'
      '  TABLE_NAME'
      ''
    )
    Params = <>
    Macros = <>
    MacroCheck = True
    Left = 150
    Top = 160
  end
