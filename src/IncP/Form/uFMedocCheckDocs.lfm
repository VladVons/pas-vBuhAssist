  object SQLQueryGridPrev: TSQLQuery[11]
    FieldDefs = <    
      item
        Name = 'EDRPOU'
        DataType = ftString
        Precision = -1
        Size = 10
      end    
      item
        Name = 'SHORTNAME'
        DataType = ftString
        Precision = -1
        Size = 100
      end    
      item
        Name = 'PERDATE'
        DataType = ftString
        Precision = -1
        Size = 8
      end    
      item
        Name = 'CHARCODE'
        DataType = ftString
        Precision = -1
        Size = 8
      end    
      item
        Name = 'FORM_NAME'
        DataType = ftString
        Precision = -1
        Size = 50
      end    
      item
        Name = 'CARDSENDSTT_NAME'
        DataType = ftString
        Precision = -1
        Size = 50
      end    
      item
        Name = 'CARDSTATUS_NAME'
        DataType = ftString
        Precision = -1
        Size = 30
      end>
    OnCalcFields = SQLQueryGridCurCalcFields
    Database = DmCommon.IBConnection
    Transaction = DmCommon.SQLTransaction
    SQL.Strings = (
      'SELECT'
      '    ORG.EDRPOU,'
      '    ORG.SHORTNAME,'
      '    CARD.PERDATE,'
      '    CARDSENDSTT.NAME AS CARDSENDSTT_NAME,'
      '    FORM.CHARCODE,'
      '    FORM.NAME AS FORM_NAME,'
      '    CARDSTATUS.NAME AS CARDSTATUS_NAME'
      'FROM'
      '    ORG'
      'LEFT JOIN CARD'
      '    ON CARD.IDORG = ORG.CODE'
      'LEFT JOIN FORM'
      '    ON FORM.CODE = CARD.FORM'
      'LEFT JOIN CARDSTATUS'
      '    ON CARDSTATUS.CODE = CARD.STATUS'
      'LEFT JOIN CARDSENDSTT'
      '    ON CARDSENDSTT.CODE = CARD.SENDSTT'
      'WHERE'
      '        (ORG.EDRPOU = :_EDRPOU)'
      '    AND (ORG.DEPT IS NULL OR ORG.DEPT <> ''0'')'
      '    AND (CARD.PERTYPE = :_PERTYPE)'
      '    AND (CARD.PERDATE = DATE %_PERDATE)'
      '    AND (CARD.IDPARENT IS NULL)'
      '    AND (CARD.FORM > 0)'
      '    AND (CARD.INTRASH = 0)'
      '    %_COND_CHARCODES'
      '    %_COND_CHARCODE_NOT'
      'ORDER BY'
      '  CHARCODE ASC'
      ''
    )
    Params = <    
      item
        DataType = ftUnknown
        Name = '_EDRPOU'
        ParamType = ptInput
      end    
      item
        DataType = ftUnknown
        Name = '_PERTYPE'
        ParamType = ptInput
      end>
    Macros = <    
      item
        DataType = ftUnknown
        Name = '_PERDATE'
        ParamType = ptInput
      end    
      item
        DataType = ftUnknown
        Name = '_COND_CHARCODES'
        ParamType = ptInput
      end    
      item
        DataType = ftUnknown
        Name = '_COND_CHARCODE_NOT'
        ParamType = ptInput
      end>
    MacroCheck = True
    Left = 128
    Top = 312
