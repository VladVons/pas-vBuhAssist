    OnCalcFields = SQLQueryCurCalcFields
    SQL.Strings = (
      'SELECT'
      '    ORG.EDRPOU,'
      '    ORG.DEPT,'
      '    ORG.SHORTNAME,'
      '    ORG.INDTAXNUM,'
      '    CASE WHEN TRIM(ORG.INDTAXNUM) <> ''100000000000'' AND TRIM(ORG.INDTAXNUM) <> '''''
      '      THEN CAST(''ПДВ'' AS VARCHAR(10))'
      '      ELSE '''''
      '    END AS vat,'
      '    T2.PERTYPE,'
      '    T2.PERDATE,'
      '    CAST(T2.PERDATE AS VARCHAR(10)) AS PERDATE_STR,'
      '    T2.CHARCODE,'
      '    T2.FORM_NAME,'
      '    T2.CARDSENDSTT_NAME,'
      '    T2.MODDATE,'
      '    T2.CARDSTATUS_NAME,'
      '    T2.STATUS2,'
      '    T2.XMLVALS,'
      '    T2.FJ'
      'FROM'
      '    ORG'
      'LEFT JOIN ('
      '    SELECT'
      '        CARD.IDORG,'
      '        CARD.PERDATE,'
      '        CARDSENDSTT.NAME || '' '' || CARD.SENDSTT AS CARDSENDSTT_NAME,'
      '        CARD.PERTYPE,'
      '        FORM.CHARCODE,'
      '        COALESCE(CARD.DOCNAME, FORM.NAME) AS FORM_NAME,'
      '        CAST(CARD.MODDATE AS DATE) AS MODDATE,'
      '        CARDSTATUS.NAME || '' '' || CARD.STATUS  AS CARDSTATUS_NAME,'
      '        CARD.STATUS || CARD.SENDSTT AS STATUS2,'
      '        CARDBLOB.XMLVALS'
      '        %_SELECT_T2'
      '    FROM'
      '      CARD'
      '    LEFT JOIN FORM'
      '        ON FORM.CODE = CARD.FORM'
      '    LEFT JOIN CARDSTATUS'
      '        ON CARDSTATUS.CODE = CARD.STATUS'
      '    LEFT JOIN CARDSENDSTT'
      '        ON CARDSENDSTT.CODE = CARD.SENDSTT'
      '    LEFT JOIN CARDBLOB'
      '        ON CARDBLOB.CODE = CARD.CODE'
      '    %_FROM_T2'
      '    WHERE'
      '            (CARD.IDPARENT IS NULL)'
      '        AND (CARD.FORM > 0)'
      '        AND (CARD.INTRASH = 0)'
      '        %_COND_PERTYPE'
      '        %_COND_PERDATE'
      '        %_COND_CHARCODE'
      '        %_COND_CHARCODE_NOT'
      '        %_COND_STATUS'
      '        %_COND_SENDSTT'
      ') T2'
      '    ON T2.IDORG = ORG.CODE'
      'WHERE'
      '    (ORG.DEPT IS NULL OR ORG.DEPT <> ''0'')'
      '    %_COND_ORG'
      'ORDER BY'
      '  %_ORDER %_ASC'
      ''
    )
    Params = <>
    Macros = <    
      item
        DataType = ftUnknown
        Name = '_SELECT_T2'
        ParamType = ptInput
      end    
      item
        DataType = ftUnknown
