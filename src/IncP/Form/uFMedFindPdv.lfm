        Size = 10
      end>
    OnCalcFields = SQLQueryCurCalcFields
    SQL.Strings = (
      'SELECT'
      '    ORG.EDRPOU,'
      '    ORG.DEPT,'
      '    ORG.SHORTNAME,'
      '    ORG.INDTAXNUM,'
      '    CASE WHEN TRIM(ORG.INDTAXNUM) <> ''100000000000'' AND TRIM(ORG.INDTAXNUM) <> '''''
      '      THEN CAST(''ПДВ'' AS VARCHAR(10))'
      '      ELSE '''''
      '    END AS vat,'
      '    T2.PERTYPE,'
      '    T2.PERDATE,'
      '    T2.CARD_CODE,'
      '    CAST(T2.PERDATE AS VARCHAR(10)) AS PERDATE_STR,'
      '    T2.CHARCODE,'
      '    T2.FORM_NAME,'
      '    --T2.CARDTABLES_TABNAME,'
      '    T2.CARDSENDSTT_NAME,'
      '    T2.MODDATE,'
      '    T2.CARDSTATUS_NAME'
      'FROM'
      '    ORG'
      'LEFT JOIN ('
      '    SELECT'
      '        CARD.CODE AS CARD_CODE,'
      '        CARD.EDRPOU AS CARD_EDRPOU,'
      '        CARD.IDORG,'
      '        CARD.PERDATE,'
      '        CARD.PERTYPE,'
      '        COALESCE(CARD.DOCNAME, FORM.NAME) AS FORM_NAME,'
      '        CAST(CARD.MODDATE AS DATE) AS MODDATE,'
      '        FORM.CHARCODE,'
      '        --CARDTABLES.TABNAME AS CARDTABLES_TABNAME,'
      '        CARDSTATUS.NAME AS CARDSTATUS_NAME,'
      '        RDSTTSPR.NAME AS CARDSENDSTT_NAME'
      '    FROM'
      '      CARD'
      '    LEFT JOIN FORM'
      '        ON FORM.CODE = CARD.FORM'
      '    --LEFT JOIN CARDTABLES'
      '    --    ON CARDTABLES.FORM = CARD.FORM'
      '    LEFT JOIN RDSTTSPR AS CARDSTATUS'
      '        ON CARDSTATUS.CODE = CARD.STATUS'
      '    LEFT JOIN RDSTTSPR'
      '        ON RDSTTSPR.CODE = CARD.SENDSTT'
      '    WHERE'
      '            (CARD.IDPARENT IS NULL)'
      '        AND (CARD.FORM > 0)'
      '        AND (CARD.INTRASH = 0)'
      '        %_COND_PERTYPE'
      '        %_COND_PERDATE'
      '        %_COND_CHARCODE'
      '        %_COND_SENDSTT'
      ') T2 ON (T2.IDORG = ORG.CODE)'
      '    AND (T2.CARD_EDRPOU = ORG.EDRPOU) -- protect EDRPOU lic'
      'WHERE'
      '    (ORG.DEPT IS NULL OR ORG.DEPT <> ''0'')'
      '    %_COND_ORG'
      'ORDER BY'
      '  %_ORDER %_ASC'
      ''
    )
    Params = <>
    Macros = <    
      item
        DataType = ftUnknown
        Name = '_COND_PERTYPE'
        ParamType = ptInput
      end    
      item
        DataType = ftUnknown
        Name = '_COND_PERDATE'
        ParamType = ptInput
      end    
      item
        DataType = ftUnknown
        Name = '_COND_CHARCODE'
        ParamType = ptInput
      end    
      item
        DataType = ftUnknown
        Name = '_COND_SENDSTT'
        ParamType = ptInput
      end    
      item
        DataType = ftUnknown
        Name = '_COND_ORG'
        ParamType = ptInput
      end    
      item
        DataType = ftUnknown
        Name = '_ORDER'
        ParamType = ptInput
      end    
      item
        DataType = ftUnknown
        Name = '_ASC'
        ParamType = ptInput
      end>
